# Application
NODE_ENV=development
PORT=3001

# Database
POSTGRES_USER=pcpricetrack
POSTGRES_PASSWORD=pcpricetrack_dev
POSTGRES_DB=pcpricetrack
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pcpricetrack:pcpricetrack_dev@localhost:5432/pcpricetrack

# Redis
REDIS_MODE=disabled
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Auth
JWT_SECRET=change_me_in_production_use_long_random_string_minimum_32_chars
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# Admin
ADMIN_SECRET=change_me_in_production

# Email (Resend)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@pcpricetrack.com

# OAuth
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Crawling
CRAWLER_CONCURRENCY=3
PROXY_URL=

# Naver Shopping API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# LLM Spec Extraction (optional — Claude Haiku for spec fallback parsing)
ANTHROPIC_API_KEY=