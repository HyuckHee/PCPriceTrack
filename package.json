{
  "name": "pcpricetrack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:setup": "bash scripts/db-setup.sh",
    "db:create-user": "bash scripts/db-create-user.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "db:migrate": "turbo run db:migrate --filter=api",
    "db:generate": "turbo run db:generate --filter=api",
    "db:seed": "turbo run db:seed --filter=api",
    "db:studio": "turbo run db:studio --filter=api"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.6.8"
}
